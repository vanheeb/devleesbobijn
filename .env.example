# --- Node env (leave as-is for dev) ----------------------------------------
NODE_ENV=development

# --- Database (Neon Postgres) ----------------------------------------------
# Copy the "pooler" connection string from the Neon dashboard.
# Must include ?sslmode=require for production.
DATABASE_URL=postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require

# --- Stripe ----------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Optional (only needed if you ever expose a publishable key to the frontend)
STRIPE_PUBLISHABLE_KEY=pk_test_...

# --- Email (Resend) --------------------------------------------------------
RESEND_API_KEY=re_...
# Must be a verified sender on your Resend-verified domain.
RESEND_FROM=De Vleesbobijn <info@devleesbobijn.be>

# --- Admin -----------------------------------------------------------------
ADMIN_EMAIL=devleesbobijn@gmail.com
# Generate with: openssl rand -base64 32
SESSION_SECRET=generate-a-long-random-string-at-least-32-chars

# Set ONCE to bootstrap the initial admin user via `npm run db:seed`.
# REMOVE after first deploy.
INITIAL_ADMIN_PASSWORD=change-me-on-first-login

# --- Site ------------------------------------------------------------------
# Development: http://localhost:5175
# Production: https://devleesbobijn.be
PUBLIC_SITE_URL=http://localhost:5175

# --- Business info (defaults; admin can override later via DB config) ------
BUSINESS_NAME=De Vleesbobijn
BUSINESS_ADDRESS=Achterstraat 20, 8540 Deerlijk
BUSINESS_PHONE=+32 479 39 22 83
BUSINESS_VAT_STATUS=Vrijgesteld van BTW
BUSINESS_IBAN=
